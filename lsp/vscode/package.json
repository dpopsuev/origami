{
  "name": "origami-pipeline-lsp",
  "displayName": "Origami Pipeline Language Support",
  "description": "Language support for Origami pipeline YAML (diagnostics, completion, hover, go-to-definition, semantic tokens, inlay hints, live Kami debugger overlay)",
  "version": "0.1.0",
  "publisher": "dpopsuev",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dpopsuev/origami"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "workspaceContains:**/pipelines/*.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "origami-pipeline",
        "aliases": [
          "Origami Pipeline",
          "origami"
        ],
        "extensions": [
          ".yaml",
          ".yml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "origami-pipeline",
        "scopeName": "source.origami-pipeline",
        "path": "./syntaxes/origami-pipeline.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Origami Pipeline",
      "properties": {
        "origami.kami.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable live Kami debugger integration for inlay hint overlays"
        },
        "origami.kami.port": {
          "type": "number",
          "default": 9800,
          "description": "Port of the Kami debugger server"
        },
        "origami.lsp.path": {
          "type": "string",
          "default": "origami",
          "description": "Path to the origami binary (must support 'origami lsp' subcommand)"
        }
      }
    },
    "semanticTokenTypes": [
      {
        "id": "origami-fire",
        "superType": "type",
        "description": "Fire element — bold, fast, confident"
      },
      {
        "id": "origami-water",
        "superType": "type",
        "description": "Water element — methodical, thorough, evidence-first"
      },
      {
        "id": "origami-earth",
        "superType": "type",
        "description": "Earth element — pragmatic, categorical"
      },
      {
        "id": "origami-air",
        "superType": "type",
        "description": "Air element — creative, lateral thinker"
      },
      {
        "id": "origami-diamond",
        "superType": "type",
        "description": "Diamond element — skeptical, evidence-demanding"
      },
      {
        "id": "origami-lightning",
        "superType": "type",
        "description": "Lightning element — dispatcher, orchestrator"
      },
      {
        "id": "origami-iron",
        "superType": "type",
        "description": "Iron element — structural, load-bearing"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "origami-pipeline",
        "scopes": {
          "origami-fire": [
            "entity.name.type.element.fire.origami"
          ],
          "origami-water": [
            "entity.name.type.element.water.origami"
          ],
          "origami-earth": [
            "entity.name.type.element.earth.origami"
          ],
          "origami-air": [
            "entity.name.type.element.air.origami"
          ],
          "origami-diamond": [
            "entity.name.type.element.diamond.origami"
          ],
          "origami-lightning": [
            "entity.name.type.element.lightning.origami"
          ],
          "origami-iron": [
            "entity.name.type.element.iron.origami"
          ]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "origami-fire": {
            "foreground": "#DC143C",
            "bold": true
          },
          "origami-water": {
            "foreground": "#007BA7"
          },
          "origami-earth": {
            "foreground": "#0047AB"
          },
          "origami-air": {
            "foreground": "#FFBF00",
            "italic": true
          },
          "origami-diamond": {
            "foreground": "#0F52BA",
            "bold": true
          },
          "origami-lightning": {
            "foreground": "#DC143C",
            "italic": true
          },
          "origami-iron": {
            "foreground": "#48494B"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "vscode-languageclient": "^9.0.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
